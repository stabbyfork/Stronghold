{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": false,
		"noEmit": false,
		"allowJs": false,
		"noErrorTruncation": true,
		"sourceMap": true,
		"outDir": "dist",
		"resolvePackageJsonExports": true,
		"jsx": "react-jsx",
		"jsxImportSource": "@dui/core",
		"paths": {
			"@dui": ["./src/dui"],
			"@dui/*": ["./src/dui/*"],
			"@dui/core": ["./src/dui/core.js"],
			"@dui/core/*": ["./src/dui/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
